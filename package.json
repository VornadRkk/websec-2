{
  "name": "websec-2-pribylka",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:backend\" \"npm:dev:client\"",
    "dev:client": "vite --config client/vite.config.js",
    "dev:backend": "nodemon --watch backend --watch .env --ext js,json,mjs backend/index.js",
    "build": "vite build --config client/vite.config.js",
    "start": "node backend/index.js"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ol": "^10.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.10",
    "vite": "^7.0.0"
  }
}
